---
extends: default

ignore: |
  .git
  .tmp
  node_modules
  web/node_modules

rules:
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1

  colons:
    max-spaces-after: -1

  commas:
    max-spaces-after: -1

  comments:
    min-spaces-from-content: 1
    require-starting-space: false

  comments-indentation: false

  indentation:
    spaces: 2
    indent-sequences: consistent

  line-length:
    max: 120

  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
